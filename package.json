{
  "name": "oscillo-synth",
  "private": true,
  "type": "module",
  "description": "A browser-based oscilloscope art and synth instrument.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/smileybones/oscillo-synth.git"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "dev": "pnpm --filter @oscillo-synth/web dev",
    "build": "pnpm --filter @oscillo-synth/web build",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
