{
  "name": "@oscillo-synth/desktop",
  "version": "0.0.0",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "package:dir": "pnpm run build && electron-builder --dir",
    "package:mac": "pnpm run build && electron-builder --mac",
    "package:win": "pnpm run build && electron-builder --win",
    "package:linux": "pnpm run build && electron-builder --linux"
  },
  "devDependencies": {
    "@oscillo-synth/ui-web": "workspace:*",
    "@types/node": "^22.0.0",
    "electron": "^39.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.7"
  }
}
